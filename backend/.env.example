# MongoDB Connection
# Local Development:
MONGODB_URI=mongodb://127.0.0.1:27017/TopBangladeshiCompaniesDB

# Production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/TopBangladeshiCompaniesDB

# JWT Configuration
# Generate a strong random string for production
# Should be at least 32 characters long
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Environment
NODE_ENV=development

# Server Port
PORT=3000

# Note: Admin credentials are now stored in MongoDB, not in .env
# To add/manage admins, use seed-admin.js or MongoDB directly
